<?xml version="1.0" encoding="UTF-8"?>
<server description="TED Processing Server">

    <!-- Enable features -->
    <featureManager>
        <!-- Jakarta EE 10 Features -->
        <feature>servlet-6.0</feature>
        
        <!-- Security Features -->
        <feature>transportSecurity-1.0</feature>
    </featureManager>

    <!-- HTTP Endpoint Configuration -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9080"
                  httpsPort="9443"
                  host="*">
        <tcpOptions soReuseAddr="true"/>
        <httpOptions removeServerHeader="true"/>
    </httpEndpoint>

    <!-- SSL Configuration with TLS 1.3 -->
    <!-- clientKeyAlias        — alias used when THIS server presents a cert on outbound calls  -->
    <!-- clientAuthenticationSupported — accepts a client cert from inbound callers if offered, -->
    <!--                                 but does not require one (no forced mTLS)              -->
    <ssl id="defaultSSLConfig"
         keyStoreRef="defaultKeyStore"
         trustStoreRef="defaultTrustStore"
         sslProtocol="TLSv1.3"
         enabledCiphers="TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256"
         clientKeyAlias="clientCert"
         trustDefaultCerts="true"/>

    <!-- Keystore Configuration -->
    <keyStore id="defaultKeyStore"
              location="${server.config.dir}/resources/security/key.p12"
              type="PKCS12"
              password="{xor}Lz4sLCgwLTs="/>

    <!-- Truststore Configuration -->
    <keyStore id="defaultTrustStore"
              location="${server.config.dir}/resources/security/key.p12"
              type="PKCS12"
              password="{xor}Lz4sLCgwLTs="/>

    <!-- Application Configuration -->
    <webApplication id="liberty-ssl-access"
                    location="liberty-ssl-access.war"
                    contextRoot="/" />

    <!-- Logging Configuration -->
    <logging traceSpecification="*=info"
             maxFileSize="20"
             maxFiles="10"
             consoleLogLevel="INFO"/>
    
    <!-- Web Application Security Configuration -->
    <webAppSecurity allowFailOverToBasicAuth="true"
                    displayAuthenticationRealm="true"
                    httpOnlyCookies="true"
                    webAlwaysLogin="true"
                    ssoRequiresSSL="true"/>
    
    <!-- Web Container Configuration -->
    <webContainer deferServletLoad="false"/>

</server>
